generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("editor") // admin, editor
  status    String   @default("active") // active, inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  color       String     @default("bg-blue-500")
  medicines   Medicine[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Medicine {
  id                Int      @id @default(autoincrement())
  name              String
  generic           String?
  category          String
  categoryRelation  Category @relation(fields: [category], references: [name])
  price             Int      @default(0)
  stock             Int      @default(0)
  unit              String   @default("Viên")
  dosage            String?
  indications       String?
  contraindications String?
  sideEffects       String?
  images            String?  // Store as JSON string or comma-separated
  isHeader          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  user      String
  action    String
  target    String
  type      String   @default("system") // create, update, delete, auth, security, system
  status    String   @default("success") // success, warning, error
  createdAt DateTime @default(now())
}
