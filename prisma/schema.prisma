// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  role      String   @default("editor") // admin, editor
  status    String   @default("active") // active, inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  color       String     @default("bg-blue-500")
  medicines   Medicine[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Medicine {
  id                Int      @id @default(autoincrement())
  name              String
  generic           String?
  category          String
  categoryRelation  Category @relation(fields: [category], references: [name])
  dosage            String?
  indications       String?
  contraindications String?
  images            String?  // Store as JSON string or comma-separated
  isHeader          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  user      String
  action    String
  target    String
  createdAt DateTime @default(now())
}
